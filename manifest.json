{
    "manifest_version": 3,
    "name": "Keyboard Layout Switcher",
    "version": "1.0.0",
    "description": "Switch text between keyboard layouts with keyboard shortcuts",
    "permissions": ["storage", "activeTab"],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["layouts.js", "utils.js", "content.js"],
            "run_at": "document_end"
        }
    ],
    "options_page": "settings/settings.html",
    "action": {
        "default_title": "Open Keyboard Layout Switcher Settings",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "commands": {
        "switch-hebrew-english": {
            "suggested_key": {
                "default": "Alt+Shift+H"
            },
            "description": "Switch between Hebrew and English"
        },
        "switch-russian-english": {
            "suggested_key": {
                "default": "Alt+Shift+R"
            },
            "description": "Switch between Russian and English"
        },
        "auto-switch": {
            "suggested_key": {
                "default": "Alt+Shift+A"
            },
            "description": "Auto-detect and switch layout"
        }
    }
}
